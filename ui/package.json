{
  "name": "slicer-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "start:web-slicer": "ng serve --host 0.0.0.0 --configuration web-slicer",
    "build": "ng build",
    "build:web-slicer": "ng build --configuration web-slicer",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "gen-schemas": "cd .. && cargo run -- gen-schemas --output-dir ui/src/schemas",
    "gen-types": "pnpm exec json2ts --declareExternallyReferenced -i \"src/schemas/*.json\" -o src/generated",
    "gen": "pnpm run gen-schemas && pnpm run gen-types"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.10",
    "@angular/aria": "^21.2.8",
    "@angular/cdk": "^21.2.8",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@types/three": "^0.184.0",
    "fuse.js": "^7.3.0",
    "iconoir": "^7.11.0",
    "ngx-markdown": "^21.2.0",
    "rxjs": "~7.8.0",
    "three": "^0.184.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
